{
  "name": "cs-pack",
  "version": "1.1.41",
  "description": "Automatic Husky + Gitleaks + SonarQube setup for any JS/TS project",
  "main": "bin/index.js",
  "bin": {
    "cs-setup": "./bin/index.js"
  },
  "keywords": [
    "husky",
    "gitleaks",
    "git-hooks",
    "security",
    "sonarqube",
    "typescript",
    "eslint"
  ],
  "author": "Husain",
  "license": "MIT",
  "scripts": {
    "postinstall": "node ./bin/index.js install",
    "test": "node --test",
    "test:smoke": "node --test",
    "test:newman": "node tests/run-newman-cloud.mjs",
    "test:all": "npm run test:smoke && npm run test:newman",
    "prepare": "node -e \"const {spawnSync}=require(\\\"child_process\\\");const r=spawnSync(process.platform===\\\"win32\\\"?\\\"npx.cmd\\\":\\\"npx\\\",[\\\"--no-install\\\",\\\"husky\\\"],{stdio:\\\"inherit\\\"});process.exit((r.status===0||r.status===null)?0:0)\""
  },
  "dependencies": {
    "@eslint/js": "^8.0.0 || ^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "chalk": "^4.1.2",
    "dotenv": "^17.3.1",
    "eslint": "^8.0.0 || ^9.0.0",
    "execa": "^5.1.1",
    "fs-extra": "^11.3.3",
    "husky": "^9.0.11",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "sonarqube-scanner": "^4.0.0"
  },
  "peerDependencies": {
    "@eslint/js": "^8.0.0 || ^9.0.0",
    "eslint": "^8.0.0 || ^9.0.0"
  },
  "peerDependenciesMeta": {},
  "files": [
    "bin/",
    "lib/",
    "templates/"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HUSAINTRIVEDI52/package_test.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^9.10.0"
  }
}
